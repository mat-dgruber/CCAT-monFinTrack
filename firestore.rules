rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funções Auxiliares ---

    // Verifica se o usuário está autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o documento pertence ao usuário (para documentos existentes)
    function isOwner(data) {
      return isSignedIn() && data.user_id == request.auth.uid;
    }

    // Verifica se o dado sendo enviado pertence ao usuário (para novos documentos)
    function isCreatingOwnedData() {
      return isSignedIn() && request.resource.data.user_id == request.auth.uid;
    }

    // --- Regras por Coleção ---

    // 1. Coleção de Usuários (Preferências e Perfil)
    match /users/{userId} {
      // O usuário pode ler seu próprio perfil
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // O usuário pode atualizar preferências, mas NÃO o tier ou tokens (proteção de negócio)
      allow update: if isSignedIn() && request.auth.uid == userId 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription_tier', 'fcm_tokens', 'uid', 'email']));
      
      // Criação e exclusão total geralmente via Backend/Admin
      allow create, delete: if false; 
    }

    // 2. Coleções de Dados do Usuário (Transactions, Accounts, Categories, Budgets, Debts, Invoices)
    // Usamos um match recursivo para subcoleções se houver
    match /{collectionName}/{docId} {
      
      // Lista de coleções que seguem o padrão de user_id
      allow read: if isSignedIn() 
                  && (collectionName in ['transactions', 'accounts', 'categories', 'budgets', 'debts', 'invoices', 'indicators', 'recurring_transactions', 'installments'])
                  && (resource == null || resource.data.user_id == request.auth.uid);

      allow create: if isSignedIn() 
                    && (collectionName in ['transactions', 'accounts', 'categories', 'budgets', 'debts', 'invoices', 'indicators', 'recurring_transactions', 'installments'])
                    && isCreatingOwnedData();

      allow update, delete: if isSignedIn() 
                            && (collectionName in ['transactions', 'accounts', 'categories', 'budgets', 'debts', 'invoices', 'indicators', 'recurring_transactions', 'installments'])
                            && isOwner(resource.data);
    }

    // 3. Bloqueio Global (Deny by Default)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
